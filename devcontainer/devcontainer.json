{
  "name": "Api",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "BASE_IMAGE": "${localEnv:BASE_IMAGE}"
    }
  },
  "workspaceFolder": "/app",
  "remoteEnv": {
    "DEVCONTAINER": "true",
    "SHELL": "/bin/zsh",
    "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}",
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },
  "mounts": [
    "source=${localEnv:HOME}/.config/github-copilot,target=/root/.config/github-copilot,type=bind,readonly",
    "source=${localEnv:HOME}/.dotfiles,target=/root/.dotfiles,type=bind",
    "source=${localEnv:HOME}/.gitignore,target=/root/.gitignore,type=bind,readonly",
    "source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind,readonly",
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,readonly",
    "source=${localEnv:HOME}/.supermaven,target=/root/.supermaven,type=bind",
    "source=${localEnv:HOME}/Documents/Notes,target=/root/Notes,type=bind",
    "source=tabz-nvim-data,target=/root/.local/share/nvim,type=volume",
    "source=tabz-zoxide,target=/root/.local/share/zoxide,type=volume",
    "source=tabz-nvim-state,target=/root/.local/state/nvim,type=volume",
    "source=tabz-nvim-cache,target=/root/.cache/nvim,type=volume",
    "source=tabz-nvim-data,target=/root/.local/share/nvim,type=volume",
    "source=tabz-nvim-state,target=/root/.local/state/nvim,type=volume",
    "source=tabz-nvim-cache,target=/root/.cache/nvim,type=volume",
    "source=tabz-znap,target=/root/.znap,type=volume"
  ],
  "workspaceMount": "source=${localWorkspaceFolder},target=/app,type=bind"
}
