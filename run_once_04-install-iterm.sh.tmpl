#!/bin/bash
set -e

{{ if eq .chezmoi.os "darwin" -}}
echo "==> Installing Nerd Font..."
brew install --cask font-meslo-lg-nerd-font

echo "==> Installing iTerm2 shell integration..."
if ! [ -e "$HOME/.iterm2_shell_integration.zsh" ]; then
  curl -L https://iterm2.com/shell_integration/zsh -o "$HOME/.iterm2_shell_integration.zsh"
fi

echo "==> Compiling terminfo entries..."
tic -x "$HOME/.config/iterm/xterm-256color-italic.terminfo"
tic -x "$HOME/.config/iterm/tmux-256color-italic.terminfo"
tic -x "$HOME/.config/iterm/xterm-24bit.terminfo"

echo "==> Importing iTerm2 color profiles..."
for profile in "$HOME/.config/iterm/"*.itermcolors; do
  open "$profile"
done
echo "  Color profiles opened in iTerm2 — accept the import prompts."
{{ end -}}
