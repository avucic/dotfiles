#!/usr/bin/env bash
# dev-up: start the devcontainer for the project rooted at $PWD.
# devcontainer.json references the base compose at
#   ${HOME}/.dotfiles/devcontainer/compose.yml
# via the dockerComposeFile array, so no merging happens here.
set -euo pipefail

# --- find nearest .devcontainer walking up from cwd ---
service_dir=""
dir="$PWD"
while [[ "$dir" != "/" ]]; do
  if [[ -d "$dir/.devcontainer" ]]; then
    service_dir="$dir/.devcontainer"
    break
  fi
  dir="$(dirname "$dir")"
done

[[ -n "$service_dir" ]] || {
  echo "dev-up: no .devcontainer/ found in $PWD or any parent" >&2
  exit 1
}

[[ -f "$service_dir/devcontainer.json" ]] || {
  echo "dev-up: missing $service_dir/devcontainer.json" >&2
  exit 1
}

# workspace = directory containing .devcontainer/  (e.g. services/epl)
project_root="$(dirname "$service_dir")"

# Ensure shared volumes exist (compose has them as `external: true`).
# Idempotent — `docker volume create X` on existing volume is a no-op.
for vol in \
    tabz-nvim-cache tabz-nvim-data tabz-nvim-state \
    tabz-zoxide tabz-znap \
    tabz-cargo tabz-rustup tabz-pnpm tabz-npm tabz-bundle; do
  docker volume create "$vol" >/dev/null
done

echo "dev-up: starting devcontainer for $project_root"

exec devcontainer up \
  --workspace-folder "$project_root" \
  --config "$service_dir/devcontainer.json" \
  --remove-existing-container \
  "$@"
