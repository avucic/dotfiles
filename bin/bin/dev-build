#!/usr/bin/env bash
# ~/.dotfiles/bin/dev-build
set -euo pipefail

# --- find nearest .devcontainer walking up from cwd ---
service_dir=""
dir="$PWD"
while [[ "$dir" != "/" ]]; do
  if [[ -d "$dir/.devcontainer" ]]; then
    service_dir="$dir/.devcontainer"
    break
  fi
  dir="$(dirname "$dir")"
done

[[ -n "$service_dir" ]] || {
  echo "dev-build: no .devcontainer/ found in $PWD or any parent" >&2
  exit 1
}

overrides="$service_dir/devcontainer.json"
[[ -f "$overrides" ]] || {
  echo "dev-build: missing $overrides" >&2
  exit 1
}

# --- read tag/base from overrides ---
# TAG = the image this service depends on (referenced as BASE_IMAGE in its Dockerfile)
# BASE_IMAGE = the upstream image to build from (UPSTREAM key, default dotfiles-box)
tag="$(jq -r '.build.args.BASE_IMAGE // empty' "$overrides")"
[[ -n "$tag" ]] || {
  echo "dev-build: overrides has no .build.args.BASE_IMAGE" >&2
  exit 1
}

base_image="$(jq -r '.build.args.UPSTREAM // "dotfiles-box"' "$overrides")"

# --- build ---
echo "dev-build: BASE_IMAGE='$base_image' \u2192 TAG='$tag'"

ssh-add ~/.ssh/id_ed25519 2>/dev/null || true

DOCKER_BUILDKIT=1 docker build \
  --no-cache \
  --ssh default \
  --build-arg BASE_IMAGE="$base_image" \
  --build-context dotfiles="$HOME/.dotfiles" \
  -t "$tag" \
  "$HOME/.dotfiles/devcontainer"
